# vs.project.toml Template
<!-- Template: assets/vs.project.toml.template -->
<!-- vibestart v3.0.0 -->

[project]
name = "$PROJECT_NAME"
version = "$PROJECT_VERSION"
annotation = "$PROJECT_ANNOTATION"
keywords = [$PROJECT_KEYWORDS]
mode = "$INSTALL_MODE"  # "lite" | "advanced"

[features]
grace = true
session_log = true
conport = $CONPORT_ENABLED  # true если выбрано в ADVANCED
entire = $ENTIRE_ENABLED    # true если выбрано в ADVANCED
batch_mode = true
design_first = true

[grace]
markup_style = "ts"  # "ts" | "py" | "generic"
log_format = "[Module][function][BLOCK_NAME] message"
verification_first = true

[session]
run_diagnostic = true
auto_update_log = true

[stack]
language = "$LANGUAGE"
runtime = "$RUNTIME"
framework = "$FRAMEWORK"
testing = "$TESTING"

[rules]
# Project-specific rules (in project repo)
local_overrides = [
  "docs/ai/project-rules.md"
]

# Optional private rules (not committed, in .gitignore)
optional_local_overrides = [
  "docs/ai/private-rules.local.md"
]

[tools.testing.mocking_policy]
prefer = "fakes"  # "fakes" | "stubs" | "mocks"
avoid = "broad monkey-patching"

[tools.observability]
logger = "console"
redaction = "Never log secrets, credentials, or raw high-risk payloads"

[batch]
task_file = "docs/BATCH_TASKS.md"
forbidden_actions = [
  "touch system prompts",
  "deploy to production",
  "modify .env files",
  "delete files"
]

[git]
# Git safety settings for vs-init
git_required = false          # If true, abort vs-init if no git repository
auto_create_tag = true        # Automatically create safety tag before changes
tag_prefix = "vs-init-backup" # Prefix for safety tags

[git.commit_format]
template = """grace(M-XXX): short description inPhase N, Step N
Module: ModuleName (src/path/to/file.ts)
Contract: one-line purpose from development-plan.xml"""

[integrations.entire]
enabled = $ENTIRE_ENABLED
cli_version = ""
checkpoints_branch = "entire/checkpoints/v1"

[integrations.conport]
enabled = $CONPORT_ENABLED
mcp_configured = false
memory_bank_path = ".conport/memory.db"

[vibestart]
version = "3.0.0"
installed_at = "$TIMESTAMP"
last_updated = "$TIMESTAMP"

[migration]
# XML migration settings for vs-init
migration_mode = "migrate"    # "migrate" | "replace" | "keep"
backup_retention = 5          # Number of backups to keep in docs/.backup/
generate_report = true        # Create migration report after migration

[gates]
require_sign_off = true
checklist = [
  "All modules in phase have STATUS=done",
  "Verification tests pass",
  "Performance targets met",
  "Founder sign-off received"
]

[policies]
system_prompts = "PLACEHOLDER_ONLY"
secrets = [
  "ANTHROPIC_API_KEY",
  "STRIPE_SECRET_KEY",
  "SUPABASE_SERVICE_ROLE_KEY"
]
rls = "ALWAYS_ON"
llm_calls = "SERVER_SIDE_ONLY"
