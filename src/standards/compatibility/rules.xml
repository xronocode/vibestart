<?xml version="1.0.0" encoding="UTF-8"?>
<Standard VERSION="1.0.0" NAME="Compatibility">
  
  <purpose>
    Detect and resolve conflicts between skills, configurations, and frameworks.
  </purpose>
  
  <conflict-types>
    
    <type id="CONF-001" category="skills">
      <name>Duplicate Skills</name>
      <description>Same skill from different sources</description>
      <example>grace-init from vibestart vs grace-marketplace</example>
      <detection>
        <location>~/.kilocode/skills/</location>
        <location>.kilocode/skills/</location>
        <location>.cursor/skills/</location>
        <location>.claude/skills/</location>
        <marker>SKILL.md with same name field</marker>
      </detection>
      <resolution>
        <option id="R1" priority="1">
          <name>vibestart-override</name>
          <description>Backup originals, install vibestart v2.0</description>
          <action>Backup to ~/.vibestart/backups/, install v2.0</action>
        </option>
        <option id="R2" priority="2">
          <name>keep-original</name>
          <description>Keep existing skills, only add vs-*</description>
          <action>No changes to existing, add new only</action>
        </option>
        <option id="R3" priority="3">
          <name>merge-manual</name>
          <description>Review each conflict manually</description>
          <action>Per-skill decision</action>
        </option>
      </resolution>
    </type>
    
    <type id="CONF-002" category="agents-md">
      <name>AGENTS.md Conflict</name>
      <description>Existing AGENTS.md vs generated from vibestart</description>
      <detection>
        <file>AGENTS.md</file>
        <marker name="vibestart">Generated from vibestart</marker>
        <marker name="grace">GRACE Framework</marker>
        <marker name="none">No generation marker</marker>
      </detection>
      <scenarios>
        <scenario id="S1">
          <condition>Exists, no generation marker</condition>
          <meaning>Manual or another framework</meaning>
          <risk>High - may lose custom rules</risk>
        </scenario>
        <scenario id="S2">
          <condition>Exists, old vibestart marker</condition>
          <meaning>Generated by older version</meaning>
          <risk>Medium - may need refresh</risk>
        </scenario>
        <scenario id="S3">
          <condition>Exists, current vibestart marker</condition>
          <meaning>Already managed by vibestart</meaning>
          <risk>Low - just update</risk>
        </scenario>
      </scenarios>
      <resolution>
        <option id="R1" priority="1">
          <name>backup-and-regenerate</name>
          <action>Save to .backup, generate new</action>
        </option>
        <option id="R2" priority="2">
          <name>keep-add-marker</name>
          <action>No content changes, add metadata</action>
        </option>
        <option id="R3" priority="3">
          <name>merge-preserve-custom</name>
          <action>Extract custom, merge with base</action>
        </option>
        <option id="R4" priority="4">
          <name>keep-original</name>
          <action>No changes</action>
        </option>
      </resolution>
    </type>
    
    <type id="CONF-003" category="config">
      <name>Configuration Conflict</name>
      <description>Multiple configuration files with overlapping settings</description>
      <detection>
        <file>vs.project.toml</file>
        <file>.cursorrules</file>
        <file>.claude/config.json</file>
        <file>.kilocode/config.json</file>
        <file>package.json (ai section)</file>
      </detection>
      <overlaps>
        <overlap>Feature flags in multiple places</overlap>
        <overlap>Stack definition conflicts</overlap>
        <overlap>Tool preferences differ</overlap>
      </overlaps>
      <resolution>
        <option id="R1" priority="1">
          <name>consolidate</name>
          <action>vs.project.toml as master, others reference it</action>
        </option>
        <option id="R2" priority="2">
          <name>keep-separate</name>
          <warning>May cause drift</warning>
        </option>
        <option id="R3" priority="3">
          <name>review-manual</name>
          <action>Manual review of each</action>
        </option>
      </resolution>
    </type>
    
    <type id="CONF-004" category="docs">
      <name>GRACE Artifacts Conflict</name>
      <description>docs/*.xml from different sources/versions</description>
      <detection>
        <file>docs/development-plan.xml</file>
        <check>VERSION attribute</check>
        <check>Structure matches template</check>
      </detection>
      <resolution>
        <option id="R1" priority="1">
          <name>migrate</name>
          <action>Backup, convert structure, add missing</action>
        </option>
        <option id="R2" priority="2">
          <name>keep-add-missing</name>
          <action>No format changes, create missing only</action>
        </option>
        <option id="R3" priority="3">
          <name>full-reset</name>
          <action>Replace all with templates</action>
          <warning>Loses existing content</warning>
        </option>
      </resolution>
    </type>
    
    <type id="CONF-005" category="session">
      <name>Session Log Conflict</name>
      <description>Existing session logs vs new structure</description>
      <detection>
        <file>docs/SESSION_LOG.md</file>
        <file>docs/TASK_LOG.md</file>
        <check>Format matches template</check>
      </detection>
      <resolution>
        <option id="R1" priority="1">
          <name>migrate-format</name>
          <action>Preserve content, update structure</action>
        </option>
        <option id="R2" priority="2">
          <name>keep-existing</name>
        </option>
        <option id="R3" priority="3">
          <name>archive-fresh</name>
          <action>Archive old, start fresh</action>
        </option>
      </resolution>
    </type>
    
    <type id="CONF-006" category="gitignore">
      <name>Gitignore Conflict</name>
      <description>Missing entries for vibestart files</description>
      <detection>
        <file>.gitignore</file>
        <required-entries>
          <entry>docs/ai/private-rules.local.md</entry>
          <entry>.env*.local</entry>
          <entry>context_portal/</entry>
        </required-entries>
      </detection>
      <resolution>
        <action>Add missing entries (non-destructive)</action>
      </resolution>
    </type>
    
  </conflict-types>
  
  <registry>
    <path>~/.vibestart/skills-registry.json</path>
    <schema>
{
  "version": "2.0.0",
  "last_updated": "ISO8601",
  "sources": {
    "vibestart": { "path": "...", "version": "..." },
    "grace-marketplace": { "path": "...", "version": "...", "status": "active|backed-up" }
  },
  "installed_skills": {
    "skill-name": {
      "source": "vibestart|grace-marketplace|custom",
      "version": "...",
      "path": "..."
    }
  },
  "conflicts_resolved": [
    {
      "date": "ISO8601",
      "skill": "...",
      "original_source": "...",
      "chosen_source": "...",
      "backup_path": "..."
    }
  ]
}
    </schema>
  </registry>
  
  <global-defaults>
    <path>~/.vibestart/global-defaults.toml</path>
    <purpose>Settings that apply to all projects unless overridden</purpose>
  </global-defaults>
  
</Standard>
