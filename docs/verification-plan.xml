  <FailureTriage>
    <protocol>
      When verification fails, produce a failure packet with:
      1. Contract/Scenario that failed
      2. Expected evidence (what should have happened)
      3. Observed evidence (what actually happened)
      4. First divergent module/function/block
      5. Suggested next action
    </protocol>
    
    <packet-template>
      FAILURE PACKET:
      - Contract: [which contract or scenario failed]
      - Expected: [what should have happened]
      - Observed: [what actually happened]
      - Divergent: [where did it go wrong]
      - Next Action: [how to fix it]
    </packet-template>
    
    <routing>
      <route issue="deterministic-failure" action="fix-file-and-retry" />
      <route issue="trace-failure" action="analyze-execution-path" />
      <route issue="integration-failure" action="check-dependencies" />
      <route issue="user-input-needed" action="request-user-decision" />
    </routing>
  </FailureTriage>

