      <depends>M-GRACEINIT</depends>
      <target>
        <source>src/skills/grace/grace-setup-subagents/SKILL.md</source>
        <tests>Manual testing with different shells</tests>
      </target>
      <observability>
        <log-prefix>[SKILL:grace-setup-subagents]</log-prefix>
      </observability>
      <verification-ref>V-M-GRACESETUP</verification-ref>
      <notes>
        <note-1>Supports Claude Code, OpenCode, Codex, Cursor, Generic shells</note-1>
      </notes>
    </M-GRACESETUP>

    <M-GRACEMULTIEXEC NAME="grace-multiagent-execute" TYPE="CORE_LOGIC" LAYER="1" ORDER="13" STATUS="planned">
      <contract>
        <purpose>Execute GRACE plan with parallel agents</purpose>
        <inputs>
          <param name="developmentPlan" type="xml" />
          <param name="safetyProfile" type="string" />
        </inputs>
        <outputs>
          <param name="executionResults" type="object" />
