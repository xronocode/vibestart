      <target>
        <source>src/skills/grace/grace-multiagent-execute/SKILL.md</source>
        <tests>Manual testing with sample project</tests>
      </target>
      <observability>
        <log-prefix>[SKILL:grace-multiagent-execute]</log-prefix>
        <critical-block>WAVE_EXECUTION, AGENT_COORDINATION</critical-block>
      </observability>
      <verification-ref>V-M-GRACEMULTIEXEC</verification-ref>
      <notes>
        <note-1>Safety profiles: conservative, balanced, aggressive</note-1>
        <note-2>Coordinates worker and reviewer agents</note-2>
      </notes>
    </M-GRACEMULTIEXEC>
  </Modules>

  <DataFlow>
    <DF-001 NAME="Framework Initialization" TRIGGER="User runs /vs-init">
      <step-1>Load framework.toml configuration</step-1>
      <step-2>Check framework integrity (7 checks)</step-2>
      <step-3>Detect conflicts (6 types)</step-3>
      <step-4>Resolve conflicts with user approval</step-4>
      <step-5>Load fragments based on features</step-5>
      <step-6>Assemble and write AGENTS.md</step-6>
      <step-7>Create vs.project.toml</step-7>
      <evidence>[SKILL:vs-init] logs, created files list</evidence>
    </DF-001>

    <DF-002 NAME="GRACE Bootstrap" TRIGGER="User runs /grace-init">
      <step-1>Gather project information</step-1>
      <step-2>Load XML templates</step-2>
      <step-3>Fill templates with project values</step-3>
      <step-4>Write docs/*.xml files</step-4>
      <step-5>Create AGENTS.md</step-5>
      <evidence>[SKILL:grace-init] logs, created files list</evidence>
    </DF-002>

    <DF-003 NAME="Module Planning" TRIGGER="User runs /grace-plan">
      <step-1>Read requirements.xml</step-1>
      <step-2>Propose module breakdown</step-2>
      <step-3>Define MODULE_CONTRACT for each</step-3>
      <step-4>Assign V-M-xxx verification refs</step-4>
      <step-5>Update development-plan.xml</step-5>
      <step-6>Update knowledge-graph.xml</step-6>
      <evidence>[SKILL:grace-plan] logs, updated XML files</evidence>
    </DF-003>
  </DataFlow>

  <ImplementationOrder>
    <Phase-1 name="Foundation" status="done">
      <goal>Core infrastructure for framework</goal>
      <step-1 module="M-CONFIG" status="done" verification="V-M-CONFIG">Framework configuration</step-1>
      <step-2 module="M-STANDARDS" status="done" verification="V-M-STANDARDS">Development standards</step-2>
      <step-3 module="M-TEMPLATES" status="done" verification="V-M-TEMPLATES">XML templates</step-3>
      <step-4 module="M-FRAGMENTS" status="done" verification="V-M-FRAGMENTS">AGENTS.md fragments</step-4>
    </Phase-1>

    <Phase-2 name="Core Skills" status="in-progress">
      <goal>Essential skills for framework operation</goal>
      <step-1 module="M-VSINIT" status="done" verification="V-M-VSINIT">Framework initialization</step-1>
      <step-2 module="M-GRACEINIT" status="done" verification="V-M-GRACEINIT">GRACE bootstrap</step-2>
      <step-3 module="M-GRACEPLAN" status="planned" verification="V-M-GRACEPLAN">Module planning</step-3>
      <step-4 module="M-GRACEEXEC" status="planned" verification="V-M-GRACEEXEC">Module execution</step-4>
      <step-5 module="M-GRACEVERIFY" status="planned" verification="V-M-GRACEVERIFY">Test strategy</step-5>
    </Phase-2>

