      <interface>
        <export-explainMethodology PURPOSE="Describe GRACE principles" />
      </interface>
      <depends>None</depends>
      <target>
        <source>src/skills/grace/grace-explainer/SKILL.md</source>
        <tests>Manual review</tests>
      </target>
      <observability>
        <log-prefix>[SKILL:grace-explainer]</log-prefix>
      </observability>
      <verification-ref>V-M-GRACEEXPLAIN</verification-ref>
      <notes>
        <note-1>Reference for new users learning GRACE</note-1>
      </notes>
    </M-GRACEEXPLAIN>

    <M-GRACEREVIEWER NAME="grace-reviewer" TYPE="UTILITY" LAYER="1" ORDER="11" STATUS="planned">
      <contract>
        <purpose>Code review with GRACE context</purpose>
        <inputs>
          <param name="codeChanges" type="object" />
        </inputs>
        <outputs>
          <param name="reviewResult" type="object" />
        </outputs>
        <errors>
          <error code="NO_CONTRACT" />
        </errors>
      </contract>
      <interface>
        <export-reviewCode PURPOSE="Check code against contracts" />
      </interface>
      <depends>M-GRACEPLAN, M-STANDARDS</depends>
      <target>
        <source>src/skills/grace/grace-reviewer/SKILL.md</source>
        <tests>Manual testing</tests>
      </target>
      <observability>
        <log-prefix>[SKILL:grace-reviewer]</log-prefix>
      </observability>
      <verification-ref>V-M-GRACEREVIEWER</verification-ref>
      <notes>
        <note-1>Checks contract compliance, standards adherence</note-1>
      </notes>
    </M-GRACEREVIEWER>

    <!-- New: Multi-agent Support -->
    <M-GRACESETUP NAME="grace-setup-subagents" TYPE="UTILITY" LAYER="1" ORDER="12" STATUS="planned">
      <contract>
        <purpose>Create GRACE subagent presets for agent shells</purpose>
        <inputs>
          <param name="shellType" type="string" />
        </inputs>
        <outputs>
          <param name="createdFiles" type="array" />
        </outputs>
        <errors>
          <error code="UNSUPPORTED_SHELL" />
        </errors>
      </contract>
      <interface>
        <export-detectShell PURPOSE="Ident agent shell type" />
        <export-createPresets PURPOSE="Generate worker, reviewer, coordinator presets" />
