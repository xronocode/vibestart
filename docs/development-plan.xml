        </errors>
      </contract>
      <interface>
        <export-answerQuestion PURPOSE="Query knowledge graph" />
      </interface>
      <depends>M-GRACEINIT</depends>
      <target>
        <source>src/skills/grace/grace-ask/SKILL.md</source>
        <tests>Manual testing</tests>
      </target>
      <observability>
        <log-prefix>[SKILL:grace-ask]</log-prefix>
      </observability>
      <verification-ref>V-M-GRACEASK</verification-ref>
      <notes>
        <note-1>Uses all GRACE artifacts for context</note-1>
      </notes>
    </M-GRACEASK>

    <M-GRACEEXPLAIN NAME="grace-explainer" TYPE="UTILITY" LAYER="1" ORDER="10" STATUS="planned">
      <contract>
        <purpose>Provide GRACE methodology reference</purpose>
        <inputs>
          <param name="topic" type="string" />
        </inputs>
        <outputs>
          <param name="explanation" type="string" />
        </outputs>
        <errors>
