          <error code="ERROR_NOT_FOUND" />
        </errors>
      </contract>
      <interface>
        <export-navigateToError PURPOSE="Find error source in knowledge graph" />
        <export-suggestFix PURPOSE="Propose fix based on contracts" />
      </interface>
      <depends>M-GRACEPLAN, M-GRACESTATUS</depends>
      <target>
        <source>src/skills/grace/grace-fix/SKILL.md</source>
        <tests>Manual testing</tests>
      </target>
      <observability>
        <log-prefix>[SKILL:grace-fix]</log-prefix>
      </observability>
      <verification-ref>V-M-GRACEFIX</verification-ref>
      <notes>
        <note-1>Uses knowledge graph to trace error to module</note-1>
      </notes>
    </M-GRACEFIX>

    <M-GRACEASK NAME="grace-ask" TYPE="UTILITY" LAYER="1" ORDER="9" STATUS="planned">
      <contract>
        <purpose>Answer questions about project using GRACE context</purpose>
        <inputs>
          <param name="question" type="string" />
        </inputs>
        <outputs>
          <param name="answer" type="string" />
        </outputs>
